---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'DUN Arquitectura — Reformas integrales y restauración de patrimonio histórico en Buenos Aires.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | DUN · estudio de arquitectura</title>

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | DUN · estudio de arquitectura`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dunarquitectura.ar" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lexend:wght@100;200;300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-dun-dark text-dun-cream antialiased font-sans">
    <!-- Nav -->
    <nav class="bg-dun-dark border-b border-dun-darker sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-4 hover:opacity-80 transition">
          <div class="ring-1 ring-dun-cream/30 rounded-sm p-1">
            <img src="/logo2.jpeg" alt="DUN estudio de arquitectura" class="h-[5rem] w-auto" />
          </div>
        </a>
        <div class="flex items-center gap-6 text-sm font-light tracking-wider text-dun-cream-dark">
          <a href="/" class="hover:text-dun-cream transition uppercase tracking-widest text-xs">Proyectos</a>
          <a href="/sobre-mi" class="hover:text-dun-cream transition uppercase tracking-widest text-xs">Sobre mí</a>
          <a
            href="/sobre-mi"
            class="border border-dun-cream text-dun-cream px-4 py-2 text-xs uppercase tracking-widest hover:bg-dun-cream hover:text-dun-dark transition"
          >
            Contacto
          </a>
        </div>
      </div>
    </nav>

    <main class="min-h-screen">
      <slot />
    </main>

    <footer class="bg-dun-cream border-t border-dun-dark/10 mt-20">
      <div class="max-w-7xl mx-auto px-6 py-12 text-center text-dun-dark">
        <div class="ring-1 ring-dun-dark/20 rounded-sm p-1 inline-block mx-auto mb-6">
          <img src="/logo3.jpeg" alt="DUN estudio de arquitectura" class="h-[7.5rem] w-auto" />
        </div>
        <p class="text-xs uppercase tracking-widest mb-1">Reformas integrales & Restauración de Patrimonio</p>
        <p class="text-xs uppercase tracking-widest">Buenos Aires, Argentina</p>
        <div class="mt-8 text-xs text-dun-muted">
          &copy; {new Date().getFullYear()} DUN · estudio de arquitectura. Todos los derechos reservados.
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  h1, h2, h3, h4 {
    font-family: 'Lexend', system-ui, sans-serif;
    font-weight: 300;
    letter-spacing: 0.05em;
  }

  .prose {
    color: #cca067;
  }

  .prose h2 {
    color: #eceadb;
    font-weight: 300;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 0.85rem;
  }

  .prose p, .prose li {
    color: #cca067;
  }

  .prose a {
    color: #eceadb;
  }
</style>
